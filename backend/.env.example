# Database / Cache
DATABASE_URL=mongodb+srv://<username>:<password>@<cluster>/<database>
REDIS_URL=redis://<username>:<password>@<host>:<port>
REDIS_HOST=<redis-host>
REDIS_PORT=6379
REDIS_USERNAME=default
REDIS_PASSWORD=<redis-password>

# Kafka
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=ante-social-backend

# Auth
JWT_SECRET=<strong-random-secret>
JWT_EXPIRATION=24h

# Service Ports
API_GATEWAY_PORT=3001
AUTH_SERVICE_PORT=3002
MARKET_ENGINE_PORT=3003
WALLET_SERVICE_PORT=3004
NOTIFICATION_SERVICE_PORT=3005
WEBSOCKET_GATEWAY_PORT=3006
ADMIN_SERVICE_PORT=3007
REPUTATION_ENGINE_PORT=3008
AUTH_SERVICE_RPC_PORT=4002
MARKET_ENGINE_RPC_PORT=4003
WALLET_RPC_PORT=4004
NOTIFICATION_RPC_PORT=4005
ADMIN_SERVICE_RPC_PORT=4007

# Optional Integrations
DARAJA_CONSUMER_KEY=
DARAJA_CONSUMER_SECRET=
DARAJA_SHORTCODE=
DARAJA_PASSKEY=
DARAJA_CALLBACK_URL=https://api.yourdomain.com/api/v1/wallet/mpesa/callback
DARAJA_ENV=sandbox
NOWPAYMENTS_API_KEY=
NOWPAYMENTS_IPN_KEY=
NOWPAYMENTS_CALLBACK_URL=https://api.yourdomain.com/api/v1/wallet/crypto/callback
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@yourdomain.com
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
EXCHANGE_RATE_API_KEY=
EXCHANGE_RATE_API_URL=https://v6.exchangerate-api.com/v6

NODE_ENV=production
