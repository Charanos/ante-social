# Database / Cache
DATABASE_URL=mongodb://localhost:27017/antesocial
MONGODB_URI=
REDIS_URL=redis://default:redispassword@localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_USERNAME=default
REDIS_PASSWORD=redispassword

# Kafka
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=ante-social-backend
KAFKA_CONSUMER_GROUP=ante-social-backend-consumer
KAFKA_AUTO_CREATE_TOPICS=true
KAFKA_TOPICS=market.events,bet.placements,wallet.transactions,notification.dispatch,user.created,compliance.flags
KAFKA_MAX_RETRIES=3
KAFKA_RETRY_SUFFIX=.retry
KAFKA_DLQ_SUFFIX=.dlq

# Auth
JWT_SECRET=<set-a-strong-random-secret-at-least-32-chars>
JWT_EXPIRATION=24h
JWT_REFRESH_SECRET=<set-a-different-strong-random-secret-at-least-32-chars>
JWT_REFRESH_EXPIRATION=7d

# Service Ports
API_GATEWAY_PORT=3001
AUTH_SERVICE_PORT=3002
MARKET_ENGINE_PORT=3003
WALLET_SERVICE_PORT=3004
NOTIFICATION_SERVICE_PORT=3005
WEBSOCKET_GATEWAY_PORT=3006
ADMIN_SERVICE_PORT=3007
REPUTATION_ENGINE_PORT=3008
AUTH_SERVICE_RPC_PORT=4002
MARKET_ENGINE_RPC_PORT=4003
WALLET_RPC_PORT=4004
NOTIFICATION_RPC_PORT=4005
ADMIN_SERVICE_RPC_PORT=4007

# CORS / Frontend
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000
WS_ALLOWED_ORIGINS=http://localhost:3000
API_GATEWAY_RATE_LIMIT_TTL=60
API_GATEWAY_RATE_LIMIT_LIMIT=180

# Feature Flags
ENABLE_NOTIFICATION_KAFKA=false
ENABLE_REPUTATION_KAFKA=false
ENABLE_WS_KAFKA=false

# Optional Integrations
DARAJA_BASE_URL=https://sandbox.safaricom.co.ke
DARAJA_CONSUMER_KEY=
DARAJA_CONSUMER_SECRET=
DARAJA_SHORTCODE=
DARAJA_PASSKEY=
DARAJA_CALLBACK_URL=http://localhost:3001/api/v1/wallet/mpesa/callback
DARAJA_B2C_SHORTCODE=
DARAJA_INITIATOR_NAME=
DARAJA_SECURITY_CREDENTIAL=
DARAJA_B2C_TIMEOUT_URL=http://localhost:3001/api/v1/wallet/mpesa/b2c-timeout
DARAJA_B2C_RESULT_URL=http://localhost:3001/api/v1/wallet/mpesa/b2c-result
DARAJA_CALLBACK_TOKEN=
DARAJA_ALLOWED_IPS=

NOWPAYMENTS_API_KEY=
NOWPAYMENTS_IPN_SECRET=
NOWPAYMENTS_IPN_KEY=
NOWPAYMENTS_IPN_URL=http://localhost:3001/api/v1/wallet/crypto/ipn
NOWPAYMENTS_CALLBACK_URL=http://localhost:3001/api/v1/wallet/crypto/callback
NOWPAYMENTS_SUCCESS_URL=http://localhost:3000/wallet/deposit/success
NOWPAYMENTS_CANCEL_URL=http://localhost:3000/wallet/deposit/cancel

SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@yourdomain.com

FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIREBASE_SERVICE_ACCOUNT_KEY=

EXCHANGE_RATE_API_KEY=
EXCHANGE_RATE_API_URL=https://v6.exchangerate-api.com/v6

# Monitoring
SENTRY_DSN=
NODE_ENV=development
