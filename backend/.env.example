# ─── Database ─────────────────────────────────────────────
MONGODB_URI=mongodb://admin:password@localhost:27017/antesocial?authSource=admin
REDIS_URL=redis://:redispassword@localhost:6379

# ─── Kafka ────────────────────────────────────────────────
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=ante-social-backend

# ─── JWT ──────────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRATION=24h

# ─── Service Ports ────────────────────────────────────────
API_GATEWAY_PORT=3001
AUTH_SERVICE_PORT=3002
MARKET_ENGINE_PORT=3003
WALLET_SERVICE_PORT=3004
NOTIFICATION_SERVICE_PORT=3005
WEBSOCKET_GATEWAY_PORT=3006
ADMIN_SERVICE_PORT=3007
REPUTATION_ENGINE_PORT=3008

# ─── Daraja (M-Pesa) ─────────────────────────────────────
DARAJA_CONSUMER_KEY=your-daraja-consumer-key
DARAJA_CONSUMER_SECRET=your-daraja-consumer-secret
DARAJA_SHORTCODE=174379
DARAJA_PASSKEY=your-daraja-passkey
DARAJA_CALLBACK_URL=https://your-domain.com/api/v1/wallet/mpesa/callback
DARAJA_ENV=sandbox

# ─── NOWPayments (Crypto) ────────────────────────────────
NOWPAYMENTS_API_KEY=your-nowpayments-api-key
NOWPAYMENTS_IPN_KEY=your-nowpayments-ipn-key
NOWPAYMENTS_CALLBACK_URL=https://your-domain.com/api/v1/wallet/crypto/callback

# ─── SendGrid (Email) ────────────────────────────────────
SENDGRID_API_KEY=your-sendgrid-api-key
SENDGRID_FROM_EMAIL=noreply@antesocial.com

# ─── Firebase (Push Notifications) ───────────────────────
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=your-firebase-client-email
FIREBASE_PRIVATE_KEY=your-firebase-private-key

# ─── Exchange Rate API ───────────────────────────────────
EXCHANGE_RATE_API_KEY=your-exchange-rate-api-key
EXCHANGE_RATE_API_URL=https://v6.exchangerate-api.com/v6

# ─── Monitoring ──────────────────────────────────────────
SENTRY_DSN=
NODE_ENV=development
